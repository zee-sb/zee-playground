{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "zee-playground",
      "runtimeExecutable": "./scripts/vercel-dev.sh",
      "runtimeArgs": [],
      "port": 3000
    },
    {
      "name": "zee-vercel-alt",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "set -a && source ./.env.local && set +a && exec /opt/homebrew/bin/vercel dev --listen 3458 --yes"],
      "port": 3458
    },
    {
      "name": "zee-static",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "dist", "-s", "-p", "3457", "--no-clipboard"],
      "port": 3457
    },
    {
      "name": "zee-vite",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3456
    }
  ]
}
