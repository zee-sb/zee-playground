# --- Required for Staffbase Companion prototype -----------------------------
# Google OAuth 2.0 client registered at console.cloud.google.com for the
# staffbase.com Workspace (OAuth consent screen → user type "Internal").
# Authorized redirect URI must match exactly: {APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Restrict sign-in to this Workspace primary domain (defaults to staffbase.com)
GOOGLE_HOSTED_DOMAIN=staffbase.com

# Atlassian OAuth 2.0 (3LO) app registered at developer.atlassian.com.
# Callback URL on the developer console must match exactly:
#   {APP_URL}/api/connections/atlassian/callback
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=

# Absolute base URL of this deployment (no trailing slash).
# In production set to https://your-domain. In `vercel dev` Vercel injects this
# automatically; you can leave it blank for local dev.
APP_URL=

# Postgres connection string (Vercel Postgres or Neon). The HTTP driver in
# @neondatabase/serverless uses this. Any of these names is checked.
DATABASE_URL=
# POSTGRES_URL=
# NEON_DATABASE_URL=

# 32-byte base64-encoded key for AES-256-GCM encryption of stored refresh
# tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENC_KEY=

# 32+ byte random secret for signing session + OAuth-state JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_JWT_SECRET=

# Staffbase SAML SSO entry point. After Google login succeeds in Companion,
# the UI surfaces a "Continue to Campsite" button that opens this URL — which
# triggers SP-initiated SAML SSO against Google IdP. Because the user already
# has a fresh Google session from the OAuth flow, the SAML round-trip is
# silent and they land authenticated in Campsite.
# Defaults to the Staffbase internal Campsite tenant if unset.
STAFFBASE_SSO_URL=https://campsite.staffbase.com/auth/saml/staffpranos

# --- Already used by the other prototypes -----------------------------------
OPENAI_API_KEY=
