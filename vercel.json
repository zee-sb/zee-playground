{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "vite --port $PORT",
  "framework": "vite",
  "functions": {
    "api/a2a.mjs": { "maxDuration": 30 },
    "api/companion/chat.mjs": { "maxDuration": 60 },
    "api/companion/confirm.mjs": { "maxDuration": 60 },
    "api/connections/atlassian/callback.mjs": { "maxDuration": 15 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/prototypes/(.*)", "destination": "/index.html" }
  ]
}
